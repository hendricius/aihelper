# Copy this file to .env and fill in the key(s) for the provider(s) you use.
# `make load-env` writes these into the app's UserDefaults before building.

# AI Coordinator API key (https://aicoordinator.spacebread.dev)
AIC_API_KEY=your-aicoordinator-key-here

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here
